# Copy to terraform.tfvars and fill in values.
# terraform.tfvars is git-ignored — never commit real credentials.

aws_profile = "shailesh-aws"
region      = "ap-south-1"
image_url   = "ACCOUNT_ID.dkr.ecr.ap-south-1.amazonaws.com/laravel-app:latest"
db_name     = "laravel"
db_user     = "admin"

# db_password is intentionally omitted.
# Supply it at plan/apply time:
#   export TF_VAR_db_password="your-secure-password"
